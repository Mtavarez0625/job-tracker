generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  password      String
  applications  Application[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Application {
  id              String     @id @default(cuid())
  company         String
  title           String
  location        String?
  salaryRange     String?
  jobLink         String?
  status          JobStatus  @default(APPLIED)
  appliedDate     DateTime?
  notes           String?
  recruiterName   String?
  recruiterEmail  String?
  nextInterview   DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  WISHLIST
  APPLIED
  RECRUITER_SCREEN
  INTERVIEW
  FINAL_INTERVIEW
  OFFER
  REJECTED
}